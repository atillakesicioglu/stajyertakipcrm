# --- Neon Postgres (Vercel Marketplace) ---
# Pooled connection (uygulama çalışma zamanı için)
DATABASE_URL="postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Doğrudan bağlantı (Prisma migration için, pooling olmadan)
# Neon + Vercel'de genelde DATABASE_URL_UNPOOLED otomatik gelir; yoksa DIRECT_URL girin
DIRECT_URL="postgres://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED="postgres://..."  # Neon Vercel alternatifi

# --- Auth.js ---
# Üret: openssl rand -base64 32
AUTH_SECRET="buraya-rastgele-secret-yazin"
# Yerel geliştirmede genelde gerekmez; production'da Vercel otomatik ayarlar
# AUTH_URL="https://your-app.vercel.app"

# --- İlk admin kullanıcısı (seed için) ---
ADMIN_EMAIL="admin@firma.com"
ADMIN_PASSWORD="degistir-bu-sifreyi"
ADMIN_NAME="Yönetici"

# --- Vercel Blob (ekran görüntüsü yükleme) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
