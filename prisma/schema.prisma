generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  INTERN
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REVISION
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(INTERN)
  theme        Theme     @default(SYSTEM)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  assignedTasks  Task[]         @relation("AssignedTasks")
  createdTasks   Task[]         @relation("CreatedTasks")
  revisions      TaskRevision[] @relation("RevisionAuthor")
  activityLogs   ActivityLog[]
  notifications  Notification[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(ASSIGNED)
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedToId String
  assignedTo   User       @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)

  createdById  String
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  submissions  TaskSubmission[]
  revisions    TaskRevision[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
}

model TaskSubmission {
  id             String   @id @default(cuid())
  textContent    String?
  screenshotUrl  String?
  screenshotName String?
  submittedAt    DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskRevision {
  id        String   @id @default(cuid())
  note      String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("RevisionAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  page      String?
  details   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  title         String
  message       String
  read          Boolean          @default(false)
  relatedTaskId String?
  createdAt     DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}
