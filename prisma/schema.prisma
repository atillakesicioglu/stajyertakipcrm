generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  INTERN
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REVISION
  BADGE_EARNED
  WEEKLY_CHAMPION
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String?
  role         Role      @default(INTERN)
  theme        Theme     @default(SYSTEM)
  notifyTaskAssigned    Boolean @default(true)
  notifyTaskSubmitted   Boolean @default(true)
  notifyTaskApproved    Boolean @default(true)
  notifyTaskRevision    Boolean @default(true)
  notifyDeadline        Boolean @default(true)
  notifyComment         Boolean @default(true)
  notifyDailySummary    Boolean @default(true)
  lastLoginAt           DateTime?
  smtpHost              String?
  smtpPort              Int?
  smtpSecure            Boolean   @default(false)
  smtpUser              String?
  smtpPasswordEnc       String?
  mailFromAddress       String?
  mailFromName          String?
  smtpLastTestedAt      DateTime?
  smtpMailEnabled       Boolean   @default(false)
  officeTasksActive       Boolean   @default(true)
  createdAt             DateTime  @default(now())

  assignedTasks           Task[]                   @relation("AssignedTasks")
  createdTasks   Task[]         @relation("CreatedTasks")
  revisions      TaskRevision[] @relation("RevisionAuthor")
  activityLogs   ActivityLog[]
  notifications  Notification[]
  dailyReports   DailyReport[]
  officeTasksCreated     OfficeTask[]           @relation("OfficeTasksCreated")
  officeTaskAssignments  OfficeTaskAssignment[]
  badges                 UserBadge[]
  weeklyChampions        WeeklyChampion[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(ASSIGNED)
  dueDate      DateTime?
  approvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedToId String
  assignedTo   User       @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)

  createdById  String
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  submissions  TaskSubmission[]
  revisions    TaskRevision[]
  starts       TaskStart[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
}

model TaskSubmission {
  id             String   @id @default(cuid())
  textContent    String?
  screenshotUrl  String?
  screenshotName String?
  submittedAt    DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskRevision {
  id        String   @id @default(cuid())
  note      String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("RevisionAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskStart {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  page      String?
  details   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  title         String
  message       String
  read          Boolean          @default(false)
  relatedTaskId String?
  createdAt     DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model DailyReport {
  id             String   @id @default(cuid())
  content        String
  screenshotUrl  String?
  screenshotName String?
  date           DateTime // Gün bazında normalize edilmiş UTC tarih (saat 00:00:00)
  createdAt      DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model OfficeTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User   @relation("OfficeTasksCreated", fields: [createdById], references: [id], onDelete: Cascade)

  assignments OfficeTaskAssignment[]

  @@index([active])
}

model OfficeTaskAssignment {
  id          String    @id @default(cuid())
  date        DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  officeTaskId String
  officeTask   OfficeTask @relation(fields: [officeTaskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([officeTaskId, date])
  @@index([userId, date])
  @@index([date])
}

model AppSettings {
  id                    String   @id @default("default")
  companyName           String   @default("Stajyer CRM")
  language              String   @default("tr")
  timezone              String   @default("Europe/Istanbul")
  dateFormat            String   @default("d MMMM yyyy")
  weekStartDay          Int      @default(1)
  currency              String   @default("TRY")
  reminderTime          String   @default("09:00")
  autoLogoutMinutes     Int      @default(60)
  notifyTaskAssigned    Boolean  @default(true)
  notifyTaskSubmitted   Boolean  @default(true)
  notifyTaskApproved    Boolean  @default(true)
  notifyTaskRevision    Boolean  @default(true)
  notifyDeadline        Boolean  @default(true)
  notifyComment         Boolean  @default(true)
  notifyDailySummary    Boolean  @default(true)
  primaryColor          String?
  successColor          String?
  warningColor          String?
  dangerColor           String?
  infoColor             String?
  neutralColor          String?
  maxFileSizeMb         Int      @default(5)
  maxStorageMb          Int      @default(1000)
  allowedFileTypes      String[] @default(["image/png", "image/jpeg", "image/webp"])
  virusScanEnabled      Boolean  @default(false)
  taskStatusConfig      Json
  updatedAt             DateTime @updatedAt
}

model UserBadge {
  id       String   @id @default(cuid())
  badgeKey String
  earnedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}

model WeeklyChampion {
  id           String   @id @default(cuid())
  weekStart    DateTime
  score        Float
  autoSelected Boolean  @default(true)
  announcedAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weekStart])
  @@index([userId])
}
